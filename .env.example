# Copy to `.env` (git-ignored) and fill in. Never commit real secrets.

# Notion internal integration token — read access to the Portfolio section. (M0.1-01)
NOTION_TOKEN=

# Notion page ID of the Portfolio parent; ingestion enumerates its subtree. (M0.1-01)
PORTFOLIO_PARENT_PAGE_ID=

# Pinecone API key — hosted embedding (Inference API) + production vector store. (M0.2-01)
PINECONE_API_KEY=

# Anthropic API key — Claude Haiku 4.5 generation, server-side only. (M0.3-01)
ANTHROPIC_API_KEY=

# Vector store backend (M4.2-01): "chroma" (local dev, default) or "pinecone" (prod hosted index).
# Selects only the STORE; embeddings are Pinecone Inference either way. Prod (.env on Lightsail)
# sets this to pinecone. Leave unset/blank locally to use Chroma.
# VECTOR_STORE=pinecone

# Production site origin added to the CORS allowlist (M4.3) — e.g. https://nicjranum.uk. Optional.
# PROD_SITE_ORIGIN=
